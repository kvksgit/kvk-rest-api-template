{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":enableVulnerabilityAlerts",
    ":semanticCommits",
    ":dependencyDashboard",
    "schedule:weekly"
  ],
  "timezone": "UTC",
  "schedule": ["before 3am on Monday"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"]
  },
  "labels": ["dependencies", "renovate"],
  "packageRules": [
    {
      "description": "Automatically merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeStrategy": "squash",
      "labels": ["dependencies", "automerged"]
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking-change"]
    },
    {
      "description": "High priority for security updates",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["patch"],
      "schedule": ["at any time"],
      "labels": ["dependencies", "security"]
    },
    {
      "description": "Group dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev dependencies",
      "schedule": ["before 3am on Monday"]
    },
    {
      "description": "Extended stability for production dependencies",
      "matchDepTypes": ["dependencies"],
      "minimumReleaseAge": "3 days",
      "labels": ["dependencies", "production"]
    },
    {
      "description": "Pin Docker digests",
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "description": "Non-major updates for TypeScript",
      "matchPackagePatterns": ["^typescript$"],
      "allowedVersions": "!/^6"
    },
    {
      "description": "Node version updates with extended stability",
      "matchPackagePatterns": ["^node$"],
      "matchDatasources": ["node"],
      "labels": ["dependencies", "node"]
    }
  ],
  "prConcurrentLimit": 3,
  "prCreationLimit": 2,
  "semanticCommits": true,
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "rangeStrategy": "bump",
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "suppressNotifications": ["prIgnoreNotification"],
  "enabledManagers": ["npm", "docker"]
}
